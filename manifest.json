<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Clip Board</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #121212;
      color: white;
    }

    header {
      padding: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #1e1e1e;
    }

    h1 {
      font-size: 18px;
    }

    .add-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: none;
      font-size: 24px;
      background: #03dac6;
      color: black;
    }

    .container {
      padding: 12px;
    }

    .card {
      background: #1e1e1e;
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 12px;
    }

    .top {
      font-size: 12px;
      opacity: 0.7;
      margin-bottom: 6px;
    }

    .middle a {
      color: #4dabf7;
      text-decoration: none;
      font-weight: bold;
      word-break: break-all;
    }

    .bottom {
      margin-top: 6px;
      font-size: 13px;
      opacity: 0.85;
    }

    /* modal */
    .modal {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: #1e1e1e;
      padding: 16px;
      display: none;
      border-top-left-radius: 16px;
      border-top-right-radius: 16px;
    }

    input, textarea {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
      border-radius: 8px;
      border: none;
    }

    .save {
      width: 100%;
      padding: 10px;
      background: #03dac6;
      border: none;
      border-radius: 8px;
    }
  </style>
</head>

<body>

<header>
  <h1>Clip Board</h1>
  <button class="add-btn" onclick="openModal()">+</button>
</header>

<div class="container" id="list"></div>

<!-- Modal -->
<div class="modal" id="modal">
  <input id="user" placeholder="Who added it?">
  <input id="link" placeholder="Clip URL">
  <textarea id="desc" placeholder="What is it about?"></textarea>
  <button class="save" onclick="addClip()">Save</button>
</div>

<script>
let clips = JSON.parse(localStorage.getItem("clips") || "[]");

function render() {
  const list = document.getElementById("list");
  list.innerHTML = "";

  clips.forEach(c => {
    list.innerHTML += `
      <div class="card">
        <div class="top">Added by ${c.user}</div>
        <div class="middle">
          <a href="${c.link}" target="_blank">Open Clip</a>
        </div>
        <div class="bottom">${c.desc}</div>
      </div>
    `;
  });
}

function openModal() {
  document.getElementById("modal").style.display = "block";
}

function addClip() {
  const user = document.getElementById("user").value;
  const link = document.getElementById("link").value;
  const desc = document.getElementById("desc").value;

  clips.unshift({ user, link, desc });

  localStorage.setItem("clips", JSON.stringify(clips));

  document.getElementById("modal").style.display = "none";

  render();
}

render();
</script>

</body>
</html> 
